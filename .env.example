VITE_API_BASE_URL=https://landed-backend-nkxx.onrender.com/api/v1
VITE_GOOGLE_CLIENT_ID=replace-with-google-oauth-web-client-id

# Backend local development
SPRING_PROFILES_ACTIVE=local
DB_URL=jdbc:postgresql://localhost:5432/landed
DB_USERNAME=landed
DB_PASSWORD=landed-local-password
JWT_SECRET=replace-with-openssl-rand-base64-64
GOOGLE_CLIENT_ID=replace-with-google-oauth-web-client-id
CORS_ALLOWED_ORIGINS=http://localhost:3000

